# Copia este archivo como .env y agrega la clave obtenida en Cohere.
COHERE_API_KEY=

# Modelo usado por ChatCohere. Puede cambiarse sin modificar el código.
COHERE_MODEL=command-a-03-2025

# Copias públicas de los documentos que usa la aplicación desplegada.
COACH_DOCS_DIR=documents

# Servidor local. Render establece WEB_HOST=0.0.0.0 y proporciona PORT.
WEB_HOST=127.0.0.1
WEB_PORT=8000
